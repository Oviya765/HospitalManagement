package com.HospitalManagement.repository;

import com.HospitalManagement.entity.LabOrder;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.stereotype.Repository;

import java.util.List;

@Repository
public interface LabOrderRepository extends JpaRepository<LabOrder, Long> {

    // 🔍 Get all orders for a patient
    List<LabOrder> findByPatient_PatientId(Long patientId);

    // 🔍 Get all orders for an encounter
    List<LabOrder> findByEncounter_EncounterId(Long encounterId);

    // 🔍 Get orders by status (ORDERED, COMPLETED, etc.)
    List<LabOrder> findByStatus(String status);

    // 🔍 Get orders by doctor
    List<LabOrder> findByOrderedBy_UserId(Long userId);

    // 🔍 Get orders by sampleId (tracking)
    LabOrder findBySampleId(String sampleId);
}
